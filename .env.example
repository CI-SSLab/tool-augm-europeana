# ── Europeana REST API ────────────────────────────────────────────────────────
# Request your key at https://api.europeana.eu/en
EUROPEANA_API_KEY=

# ── Ollama ────────────────────────────────────────────────────────────────────
# When running via docker compose this is set automatically to the ollama
# container. Override only if you point to an external Ollama instance.
# OLLAMA_BASE_URL=http://ollama:11434

# Model to use (must be pulled inside the ollama container first)
OLLAMA_MODEL=openai/gpt-oss:20b

# Only required when using Ollama Cloud (leave empty for local container)
OLLAMA_API_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
# Exposed port for the Streamlit UI (default: 8501)
# APP_PORT=8501
